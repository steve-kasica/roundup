{
  "name": "roundup",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:docs": "bundle exec jekyll serve -s docs -d build/docs",
    "build": "npm run build:docs && vite build",
    "build:docs": "bundle exec jekyll build -s docs -d build/docs",
    "preview": "python3 -m http.server --directory build",
    "clean": "rm -rf build",
    "lint": "eslint .",
    "test": "vitest",
    "test:cy": "cypress run --component",
    "test:cy:open": "cypress open --component",
    "project-stats": "bash ./bin/project-stats.sh",
    "deploy": "npm run build && bash ./bin/deploy.sh"
  },
